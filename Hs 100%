<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <title>Treino de Mira</title>
  <style>
    body {
      background: #111;
      color: white;
      text-align: center;
      font-family: Arial;
    }
    .alvo {
      width: 50px;
      height: 50px;
      background: red;
      border-radius: 50%;
      position: absolute;
      cursor: pointer;
    }
  </style>
</head>
<body>

<h1>Treino de Mira (Headshot)</h1>
<p>Pontuação: <span id="score">0</span></p>

<div id="alvo" class="alvo"></div>

<script>
  let score = 0;
  const alvo = document.getElementById("alvo");

  function moverAlvo() {
    const x = Math.random() * (window.innerWidth - 50);
    const y = Math.random() * (window.innerHeight - 50);
    alvo.style.left = x + "px";
    alvo.style.top = y + "px";
  }

  alvo.onclick = () => {
    score++;
    document.getElementById("score").innerText = score;
    moverAlvo();
  };

  moverAlvo();
</script>

</body>
</html>
